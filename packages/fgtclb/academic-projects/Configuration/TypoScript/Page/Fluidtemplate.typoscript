[traverse(page, "doktype") == 30]
  page {
    10 {
      paths {
        10 = EXT:academic_projects/Resources/Private/
      }
      dataProcessing {
        100 = project-data
        110 = files
        110 {
          references.fieldName = media
          as = images
        }
      }
    }
  }
[END]
