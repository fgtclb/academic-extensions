{
    "name": "fgtclb/academic-base",
    "description": "Base functionality accross academic extensions",
    "type": "typo3-cms-extension",
    "homepage": "https://www.fgtclb.com/",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3 || ^8.4",
        "fgtclb/environment-state-manager": "^1.0",
        "symfony/config": "^6.4.26 || ^7.3.4",
        "symfony/serializer": "^6.4.26 || ^7.3.4",
        "typo3/class-alias-loader": "^1.2",
        "typo3/cms-core": "^12.4.22 || ^13.4"
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "FGTCLB\\AcademicBase\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FGTCLB\\AcademicBase\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "academic_base"
        },
        "typo3/class-alias-loader": {
            "class-alias-maps": [
                "Migrations/Code/ClassAliasMap.php"
            ]
        },
        "branch-alias": {
            "dev-main": "2.4.x-dev"
        },
        "sbuerk/release": {
            "tailor": {
                "require": {
                    "symfony/config": "^6.4.26",
                    "symfony/serializer": "^6.4.26"
                }
            }
        }
    }
}
